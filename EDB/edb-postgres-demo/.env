COMPOSE_PROJECT_NAME=edb_postgres_demo

# OSS demo images
POSTGRES_IMAGE=edb-demo-postgres:16-bookworm
POSTGRES_EXPORTER_IMAGE=edb-demo-postgres-exporter:v0.15.0
PROMETHEUS_IMAGE=edb-demo-prometheus:v2.54.1
GRAFANA_IMAGE=edb-demo-grafana:11.1.4
HAPROXY_IMAGE=edb-demo-haproxy:2.9

# Demo credentials only. Do not reuse in production.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_demo_password
POSTGRES_DB=postgres
DEMO_DB=demo
APP_READONLY_PASSWORD=readonly_demo_password
APP_WRITER_PASSWORD=writer_demo_password
APP_ADMIN_PASSWORD=admin_demo_password
REPLICATION_USER=replicator
REPLICATION_PASSWORD=replicator_demo_password
BARMAN_USER=barman
BARMAN_PASSWORD=barman_demo_password

# Ports
PG_PRIMARY_PORT=5432
PG_STANDBY_PORT=5433
PG_RESTORE_PORT=5434
EFM_NODE1_PORT=5441
EFM_NODE2_PORT=5442
EFM_NODE3_PORT=5443
PGD_NODE1_PORT=5451
PGD_NODE2_PORT=5452
PGD_NODE3_PORT=5453
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
HAPROXY_PORT=15432

# EDB template mode placeholders.
EDB_POSTGRES_IMAGE=registry.connect.redhat.com/enterprisedb/edb-postgres-advanced:replace-with-licensed-tag
EDB_EFM_IMAGE=registry.connect.redhat.com/enterprisedb/edb-efm:replace-with-licensed-tag
EDB_PGD_IMAGE=registry.connect.redhat.com/enterprisedb/edb-postgres-distributed:replace-with-licensed-tag
EDB_REPO_USERNAME=replace-me
EDB_REPO_PASSWORD=replace-me
